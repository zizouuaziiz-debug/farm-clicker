# =============================================================================
# Farm Clicker — Environment Variables
# =============================================================================
# Copy this file to `.env` locally, or set these as project variables in your
# hosting dashboard. This project deploys as three separate services:
#   - artifacts/api-server   -> Railway  (or any Node host)
#   - artifacts/farm-clicker -> Vercel   (the Telegram Mini App game)
#   - artifacts/farm-admin   -> Vercel   (the admin panel)
# Each variable below is annotated with which service reads it.

# -----------------------------------------------------------------------------
# Database (artifacts/api-server, lib/db)
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Drizzle ORM.
# Example: postgresql://user:password@host:5432/farm_clicker
DATABASE_URL=

# -----------------------------------------------------------------------------
# Server (artifacts/api-server) — set these in Railway's service variables
# -----------------------------------------------------------------------------
# Port the API server listens on. Railway sets this automatically — do not
# override it in the Railway dashboard, the platform injects its own value.
PORT=8080

# Node environment. Use "production" for deployed environments — this
# enables stricter checks (e.g. SESSION_SECRET/TELEGRAM_BOT_TOKEN become
# mandatory, ALLOW_MOCK_AUTH is ignored).
NODE_ENV=production

# Comma-separated list of allowed CORS origins for the API server. Must list
# the exact Vercel URLs of both frontends (no trailing slash), e.g.:
# ALLOWED_ORIGINS="https://farm-clicker.vercel.app,https://farm-admin.vercel.app"
# Update this whenever you add a custom domain or a Vercel preview URL you
# need to test against.
ALLOWED_ORIGINS=

# Log level for the pino logger (e.g. trace, debug, info, warn, error).
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Authentication (artifacts/api-server/src/lib/auth.ts)
# -----------------------------------------------------------------------------
# Secret used to sign session cookies/tokens. Required in production; the
# server will refuse to start without it.
SESSION_SECRET=

# Telegram bot token used to verify Telegram Mini App auth payloads.
# Required in production; get this from @BotFather.
TELEGRAM_BOT_TOKEN=

# Public @username of the Telegram bot (used to build deep links, e.g. in
# referral URLs). Does not include the leading @.
TELEGRAM_BOT_USERNAME=

# When set to "true" in a non-production environment, the API server accepts
# a mock authenticated user instead of validating a real Telegram payload.
# This lets you run the game locally/in dev without a live bot. Never set
# this to "true" in production.
ALLOW_MOCK_AUTH=false

# One-time secret required to call the admin bootstrap endpoint that creates
# the first admin user. Leave unset to disable that endpoint entirely.
ADMIN_SETUP_SECRET=

# -----------------------------------------------------------------------------
# Game configuration (artifacts/api-server/src/lib/game-config.ts) — Railway
# -----------------------------------------------------------------------------
# Destination wallet address shown to players for VIP purchase payments.
VIP_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Frontend build (artifacts/farm-clicker, artifacts/farm-admin) — set these as
# Vercel Project → Settings → Environment Variables for EACH of the two
# Vercel projects (farm-clicker and farm-admin).
# -----------------------------------------------------------------------------
# Full URL of the deployed API server (Railway), no trailing slash. Both
# frontends call the API on a different origin, so this MUST be set on both
# Vercel projects or API requests will fail.
# Example: VITE_API_BASE_URL=https://farm-clicker-api.up.railway.app
VITE_API_BASE_URL=

# Your real Adsgram block ID (from your Adsgram publisher dashboard). Only
# needed on the farm-clicker Vercel project. Falls back to a demo/test block
# ID if unset — real ads will not serve until this is set.
VITE_ADSGRAM_BLOCK_ID=

# BASE_PATH / PORT are no longer required for a Vercel build — both frontends
# default to BASE_PATH=/ and only use PORT for the local dev server. Leave
# these unset on Vercel.
